text_2_0 = "Лицензировано на "
text_2_1 = " -  представлено"
text_2_4 = "Программа по внешней баллистике для плоских траекторий в постоянной атмосфере |true,False,true,0"
text_2_5 = "(Дополнение к программе QuickLOAD – Программе по Внутренней Баллистике)"
text_2_6 = "Эта программа рассчитывает траектории снарядов с использованием G1- функции сопротивления воздуха. Баллистический коэффициент C1 "
text_2_7 = "используется основными производителями спортивных боеприпасов в США для расчета траекторий большинства"
text_2_8 = "спортивных пуль. Баллистические коэффициенты, перечисленные в инструкциях по ручному переснаряжению, основаны на таблицах 'G1' или"
text_2_9 = "'INGALLS'. Другие функции сопротивления, такие как 'GW', 'G2' или 'J', 'G5,G7,G8', и т.д. были разработаны и"
text_2_10 = "используются для снарядов военных образцов. В отличии от G1 они используют различные баллистические коэффициенты, которые невозможно"
text_2_11 = "найти в инструкциях по ручному переснаряжению. Функция сопротивления G1 позволяет получать реалистические траектории до 500 ярдов со"
text_2_12 = "спортивными пулями. Рассчитанная траектория может отличаться от реальной траектории на более длинных дистанциях. Круглые пули,"
text_2_13 = "пули для гладких стволов и пули-пыжерубы могут быть рассчитаны только для очень коротких дальностей."
text_2_14 = "О Т К А З |true,False,FALSE,0"
text_2_15 = "Данное программное обеспечение лицензировано >КАК ЕСТЬ< и распространяется без каких-либо гарантий по эксплуатационным качествам или по товарному состоянию.|true,False,TRUE,0"
text_2_16 = "Наша полная ответственность может заключаться, по нашему выбору, либо в возвращении продажной стоимости либо в замене программного обеспечения. Так как |true,False,true,0"
text_2_17 = " мы не контролируем компоненты и оборудование, которое может быть использовано вместе с данным программным обеспечением, мы не берем на себя и не несем |true,False,true,0"
text_2_18 = " никакой ответственности за любые результаты, которые может получить пользователь. Пользователь должен осознавать весь риск использования данной программы |true,False,true,0"
text_2_19 = "и данных. В максимальной степени, разрешенной действующим законодательством, в никаких случаях продавец или производитель не|true,False,true,0"
text_2_20 = " несут ответственности за любые виды ущерба (включая, без ограничений, прямой или косвенный ущерб, человеческие увечья|true,False,true,0"
text_2_21 = " или смерть, коммерческие потери или любые другие финансовые потери) вытекающие из использования обладателем лицензии или невозможностью использовать это программное обеспечение.|true,False,true,0"
text_2_22 = ""
text_2_23 = "Предупреждение: Данное программное обеспечение охраняется законом об авторских правах и международными соглашениями."
text_2_24 = "Неавторизованное воспроизведение или разборка данной программы, или любой составной части, влечет"
text_2_25 = "полную гражданскую и уголовную ответственность и будет пресекаться в максимальной степени, возможной в соответствии с законом"
text_2_26 =
text_2_27 = "Если вы не согласны с этим условиями, выйдите из этой программы нажав кнопку ВЫЙТИ !|true,False,true,255"

