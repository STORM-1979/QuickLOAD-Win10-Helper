text_2_0 = "Licensed to "
text_2_1 = " -  distributed"
text_2_4 = "Exterior ballistics program for flat trajectories in constant atmosphere |true,False,true,0"
text_2_5 = "(Add-on companion program for QuickLOAD - Interior Ballistics Program)"
text_2_6 = " This program calculates the trajectories of projectiles using the G1 or G7 drag function. "
text_2_7 = " The G1 / C1 ballistic coefficient is used by the major manufacturers of sporting ammunition and bullets in the"
text_2_8 = "  USA to calculate the trajectories of most sporting bullets. Other drag functions such as 'GW', 'G2'or 'J',"
text_2_9 = "  'G5, G8', etc. have been established and are used for military style projectiles. In contrast to G1 they need "
text_2_10 = " different ballistic coefficients which are normally not found in handloader's manuals. The G1 drag"
text_2_11 = " function delivers realistic trajectories with normal sporting bullets. For boattailed spitzer bullets"
text_2_12 = " the G7 function matches best. The calculated trajectory may differ from the real trajectory at long ranges,"
text_2_13 = " above 600 yards. Round balls, shotgun slugs and wadcutter bullets could only be calculated for very short ranges."
text_2_14 = "DISCLAIMER|true,False,true,0"
text_2_15 = "This software is licensed >as is< and without warranties as to performance or merchantability.|true,False,true,0"
text_2_16 = "Our entire liability shall be at our option, either return of purchase price or replacement of the software. Since|true,False,true,0"
text_2_17 = "we have no control over the components and equipment which may be used with this program, no responsibility|true,False,true,0"
text_2_18 = "is implied or assumed for results obtained through its use. The user must assume the entire risk of using program|true,False,true,0"
text_2_19 = "and data. To the maximum extend permitted by applicable law, in no event shall the seller or manufacturer be|true,False,true,0"
text_2_20 = "liable for any damages whatsoever (including without limitation, direct or indirect damages for personal injury|true,False,true,0"
text_2_21 = "or death, business losses, or any other pecuniary loss) arising out of the use of or inability to use this software.|true,False,true,0"
text_2_22 = ""
text_2_23 = "Warning:   This computer program is protected by copyright laws and international treaties."
text_2_24 = "Unauthorized reproduction or distribution or reverse engineering of this program, or any portion of it, may"
text_2_25 = "result in severe civil and criminal penalties, and will be prosecuted to the maximum extend possible under law."
text_2_26 =
text_2_27 = "If you do not agree to this terms, leave this program by pressing the EXIT - Button !|true,False,true,255"

